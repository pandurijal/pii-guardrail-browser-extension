{
  "name": "privacy-guardrail",
  "version": "0.2.4",
  "private": true,
  "description": "Chrome extension that detects and replaces PII before pasting into LLM chats",
  "scripts": {
    "build:wasm": "cd crate && cargo build --release --target wasm32-unknown-unknown && wasm-bindgen --target web --out-dir pkg --out-name privacy_guardrail_wasm target/wasm32-unknown-unknown/release/privacy_guardrail_wasm.wasm",
    "build:ext": "webpack --mode production",
    "build": "npm run build:wasm && npm run build:ext",
    "dev": "webpack --mode development --watch",
    "prepare:model:ai4privacy": "node scripts/prepare-ai4privacy-model.js",
    "prepare:model:bardsai": "node scripts/prepare-bardsai-model.js",
    "prepare:model:hikmaai": "node scripts/prepare-hikmaai-model.js",
    "convert:model:fp16": "node scripts/convert-source-models-to-fp16.js",
    "convert:model:fp16:bardsai": "node scripts/convert-source-models-to-fp16.js --model bardsai",
    "convert:model:fp16:hikmaai": "node scripts/convert-source-models-to-fp16.js --model hikmaai",
    "version:set": "node scripts/version.js set",
    "version:check": "node scripts/version.js check",
    "validate:ci": "node scripts/validate.js ci",
    "validate:release-strict": "node scripts/validate.js release-strict",
    "package:release": "node scripts/package-release.js release",
    "package:dry-run": "node scripts/package-release.js dry-run",
    "test": "jest --config jest.config.js",
    "test:ner:model": "jest --config jest.local-model.config.js",
    "test:rust": "cd crate && cargo test",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.svelte.json",
    "check:permissions": "node scripts/check-extension-permissions.js",
    "check:privacy-boundary": "node scripts/check-privacy-boundary.js",
    "benchmark:openpii": "node scripts/run-openpii-benchmark.js",
    "benchmark:openpii:download": "node scripts/download-openpii-dataset.js",
    "benchmark:openpii:build": "node scripts/build-openpii-corpus.js",
    "lint": "eslint src/ --ext .ts",
    "clean": "rm -rf dist crate/pkg crate/target"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "adm-zip": "^0.5.17",
    "chrome-types": "^0.1.297",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "30.3.0",
    "mini-css-extract-plugin": "^2.9.1",
    "svelte": "5.55.5",
    "svelte-check": "4.4.8",
    "svelte-loader": "3.2.4",
    "svelte-preprocess": "6.0.3",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0"
  }
}
